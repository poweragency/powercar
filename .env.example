# Supabase (client + server)
NEXT_PUBLIC_SUPABASE_URL=https://jconofgquajgzylcfnfg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_FbGVgARnOgaOrustMbcMUw_hhGoARcb

# Service role (SERVER ONLY - mai esporre al client!)
# Necessaria per il webhook Facebook che scrive bypassando RLS
SUPABASE_SERVICE_ROLE_KEY=

# Facebook App secret (per verifica firma X-Hub-Signature-256)
# App Meta dedicata: "PowerCar". Webhook di produzione (oggetto Page, campo leadgen):
#   https://powercar.poweragency.it/api/webhooks/facebook
# Si configura UNA volta sola per tutta l'app, non per singola carrozzeria.
# Ogni carrozzeria poi collega la propria Page + Access Token dalla pagina /settings del CRM.
FB_APP_SECRET=

# System User token "PowerCar Backend" (BM Poweragency) — SERVER ONLY, "chiave madre".
# Usato da /api/fb/connect-page per il "Collega automaticamente" in /settings:
# genera il page token, iscrive la pagina ai lead e lo salva sul workshop.
# Una volta sola per tutta l'app. NON salvarlo nel DB. Ruotarlo invalida i page token derivati.
FB_SYSTEM_USER_TOKEN=

# Resend (notifiche email cliente). Lascia vuoto per disabilitare l'invio reale.
# Crea l'API key su https://resend.com/api-keys e verifica il dominio mittente.
RESEND_API_KEY=
RESEND_FROM_EMAIL="PowerCar <noreply@example.com>"

# Upstash Redis (rate limiting distribuito, consigliato in produzione serverless).
# Se assenti, il rate limiting resta in-memory per-istanza (fallback automatico).
# Crea un database su https://console.upstash.com/ e copia URL + token REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
